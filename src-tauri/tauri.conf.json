{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ebook-to-mindmap",
  "version": "0.1.0",
  "identifier": "com.mind-elixir.ebook-to-mindmap",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "电子书转思维导图",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "AI-powered ebook to mind map converter",
    "longDescription": "Convert EPUB and PDF ebooks into structured mind maps and summaries using AI."
  }
}
